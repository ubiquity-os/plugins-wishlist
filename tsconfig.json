{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["jest"],
    "outDir": "./dist",
    "declaration": false,
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "contributor-rewards-with-config/src/**/*.ts", "proposals/webhook-rewards/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
